{
  "package_id": "com.natealmanza.roadview",
  "edition": "202601",
  "name": "Road View",
  "version": "1.5.3",
  "min_app_version": "2.1.0",
  "min_sdk_version": "0.0.9",
  "entrypoint": "index.html",
  "permissions": [
    {
      "name": "network",
      "desc": "Fetches WSDOT highway camera metadata and live camera images from WSDOT and third-party hosts.",
      "whitelist": [
        "https://evenhub.evenrealities.com/*",
        "https://wsdot.wa.gov/*",
        "https://www.wsdot.wa.gov/*",
        "https://images.wsdot.wa.gov/*",
        "https://cam.pangbornairport.com/*",
        "https://w28webcam.blob.core.windows.net/*",
        "https://flyykm.com/*",
        "https://assets2.webcam.io/*",
        "https://www.nps.gov/*",
        "https://sunmountainlodge.com/*",
        "https://www.seattle.gov/*",
        "https://www.tripcheck.com/*",
        "https://home.lewiscounty.com/*",
        "https://tripcheck.com/*",
        "https://roadview-proxy.roadview.workers.dev/*"
      ]
    }
  ],
  "supported_languages": ["en"]
}
